{
    "name": "lavalpine/core",
    "description": "A SaaS-ready Laravel starter kit combining Livewire Volt and Alpine.js with a global dynamic modal and toast system, styled with Tailwind CSS.",
    "keywords": ["laravel", "livewire", "volt", "alpinejs", "tailwind", "modal", "starter-kit"],
    "license": "MIT",
    "authors": [
        {
            "name": "Fabian Syah Al Ghiffari",
            "email": "fabiansyahalghiffarireal@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "livewire/volt": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Lavalpine\\Core\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lavalpine\\Core\\LavalpineServiceProvider"
            ]
        }
    }
}
